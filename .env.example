# Copy this file to .env and fill in real values.
# .env is read by docker-compose and passed into the backend/postgres/bot
# containers as environment variables.

# --- Django -------------------------------------------------------------
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL -----------------------------------------------------------
# These are consumed both by the official postgres image (POSTGRES_DB,
# POSTGRES_USER, POSTGRES_PASSWORD are its documented variable names) and
# by Django's DATABASES setting.
POSTGRES_DB=game_key_store
POSTGRES_USER=game_key_store
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Telegram bot ---------------------------------------------------------
BOT_TOKEN=change-me

# TODO: STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET once Stripe is added.
# TODO: TELEGRAM_PROVIDER_TOKEN once Telegram Stars payments are added.
# TODO: REDIS_URL / CELERY_BROKER_URL once Celery + Redis are added.
